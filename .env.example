# @BotFather dan olingan bot tokenini shu yerga qo'ying.
# Bu faylni .env deb nusxalang:  cp .env.example .env
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# (Ixtiyoriy) Foydalanuvchi sozlamalari va javob tarixi saqlanadigan papka.
# Lokalda ./data yetarli. Railway'da o'zgarishlar saqlanishi uchun Volume ulab,
# uning yo'lini shu yerga bering (masalan /data).
# DATA_DIR=./data

# (Ixtiyoriy) Kunlik eslatma yuboriladigan soat (Toshkent vaqti, 0-23). Standart: 19.
# REMIND_HOUR=19

# (Ixtiyoriy) Admin panel uchun Telegram ID'lar (vergul bilan).
# Botга /myid yozib ID'ingizni oling, keyin shu yerga (yoki Railway Variables'ga) qo'ying.
# ADMIN_IDS=117476035
